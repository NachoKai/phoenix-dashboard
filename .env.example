PORT=3001

# ── Database ──
# Default: uses a local SQLite file at backend/data/dashboard.db (no setup needed for dev)
# For production persistence across deploys, use Turso (free tier at turso.tech):
#   1. Install: npm install -g turso
#   2. Create DB: turso db create phoenix-dashboard
#   3. Get URL:  turso db show phoenix-dashboard --url
#   4. Get token: turso db tokens create phoenix-dashboard
# Then set:
# TURSO_DATABASE_URL=libsql://phoenix-dashboard-<org>.turso.io
# TURSO_AUTH_TOKEN=<your-token>
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Data directory for persistent SQLite file (optional — defaults to backend/data/)
# DATA_DIR=/data
ENCRYPTION_KEY=change-me-to-a-32-byte-random-string!!
OPENWEATHER_API_KEY=
GIPHY_API_KEY=

# OpenRouter API (for AI Q&A widget — get a free key at openrouter.ai)
OPENROUTER_API_KEY=

# Tuya IoT Platform (for lights & vacuum widgets)
# Get these from https://iot.tuya.com → your cloud project
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_ENDPOINT=https://openapi.tuyaus.com
# Comma-separated list of known device IDs (fallback when device listing fails)
TUYA_KNOWN_DEVICE_IDS=
# Optional: user login (requires linked app account for user-level API access)
TUYA_USER_EMAIL=
TUYA_USER_PASSWORD=
TUYA_COUNTRY_CODE=54
TUYA_APP_SCHEMA=tuyaSmart

# Dashboard password (required — set in .env)
VITE_DASHBOARD_PASSWORD=change-me
