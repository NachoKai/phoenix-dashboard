PORT=3001

# Data directory for persistent state (optional — defaults to backend/data/)
# Set this to a persistent path when deploying via Docker to survive container rebuilds
# DATA_DIR=/data
ENCRYPTION_KEY=change-me-to-a-32-byte-random-string!!
OPENWEATHER_API_KEY=
GIPHY_API_KEY=

# OpenRouter API (for AI Q&A widget — get a free key at openrouter.ai)
OPENROUTER_API_KEY=

# Tuya IoT Platform (for lights & vacuum widgets)
# Get these from https://iot.tuya.com → your cloud project
TUYA_ACCESS_ID=
TUYA_ACCESS_SECRET=
TUYA_ENDPOINT=https://openapi.tuyaus.com
# Comma-separated list of known device IDs (fallback when device listing fails)
TUYA_KNOWN_DEVICE_IDS=
# Optional: user login (requires linked app account for user-level API access)
TUYA_USER_EMAIL=
TUYA_USER_PASSWORD=
TUYA_COUNTRY_CODE=54
TUYA_APP_SCHEMA=tuyaSmart

# Dashboard password (required — set in .env)
VITE_DASHBOARD_PASSWORD=change-me
